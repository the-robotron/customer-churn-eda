 "cells": [
  {
   "cell_type": "markdown",
   "id": "title",
   "metadata": {},
   "source": [
    "# Customer Churn EDA\n",
    "**Author:** Shivam Singh | **Dataset:** IBM Telco Customer Churn | **Tools:** Python, Pandas, Seaborn, Matplotlib"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "intro",
   "metadata": {},
   "source": [
    "## 1. Introduction\n",
    "This notebook performs Exploratory Data Analysis (EDA) on the IBM Telco Customer Churn dataset.\n",
    "The goal is to understand what factors drive customers to churn, so the business can take proactive retention actions."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "imports",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Plot style\n",
    "sns.set_theme(style='darkgrid', palette='muted')\n",
    "plt.rcParams['figure.figsize'] = (10, 6)\n",
    "print('Libraries loaded successfully.')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section2",
   "metadata": {},
   "source": ["## 2. Load & Inspect Data"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "load",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv('../data/telco_churn.csv')\n",
    "print(f'Shape: {df.shape}')\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "info",
   "metadata": {},
   "outputs": [],
   "source": [
    "df.info()\n",
    "print('\\nMissing values:')\n",
    "print(df.isnull().sum()[df.isnull().sum() > 0])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "describe",
   "metadata": {},
   "outputs": [],
   "source": ["df.describe(include='all'")
  },
  {
   "cell_type": "markdown",
   "id": "section3",
   "metadata": {},
   "source": ["## 3. Data Cleaning"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "clean",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Convert TotalCharges to numeric (contains spaces for new customers)\n",
    "df['TotalCharges'] = pd.to_numeric(df['TotalCharges'], errors='coerce')\n",
    "\n",
    "# Drop rows with missing TotalCharges (only 11 rows)\n",
    "df.dropna(subset=['TotalCharges'], inplace=True)\n",
    "\n",
    "# Encode target variable\n",
    "df['Churn'] = df['Churn'].map({'Yes': 1, 'No': 0})\n",
    "\n",
    "# Drop customerID (not useful for analysis)\n",
    "df.drop(columns=['customerID'], inplace=True)\n",
    "\n",
    "print(f'Clean dataset shape: {df.shape}')\n",
    "print(f'Churn rate: {df.Churn.mean()*100:.1f}%')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section4",
   "metadata": {},
   "source": ["## 4. Univariate Analysis"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "churn_dist",
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n",
    "\n",
    "# Churn count\n",
    "sns.countplot(x='Churn', data=df, palette='Set2', ax=axes[0])\n",
    "axes[0].set_title('Churn Distribution (Count)', fontsize=14)\n",
    "axes[0].set_xticklabels(['No Churn', 'Churn'])\n",
    "\n",
    "# Churn percentage\n",
    "churn_pct = df['Churn'].value_counts(normalize=True) * 100\n",
    "axes[1].pie(churn_pct, labels=['No Churn', 'Churn'], autopct='%1.1f%%',\n",
    "            colors=['#66b3ff','#ff9999'], startangle=90)\n",
    "axes[1].set_title('Churn Distribution (%)', fontsize=14)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../images/churn_distribution.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section5",
   "metadata": {},
   "source": ["## 5. Bivariate Analysis"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "contract_churn",
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 3, figsize=(16, 5))\n",
    "\n",
    "cat_vars = ['Contract', 'InternetService', 'PaymentMethod']\n",
    "for i, col in enumerate(cat_vars):\n",
    "    churn_rate = df.groupby(col)['Churn'].mean() * 100\n",
    "    churn_rate.sort_values().plot(kind='barh', ax=axes[i],\n",
    "                                   color='steelblue', edgecolor='white')\n",
    "    axes[i].set_title(f'Churn Rate by {col}', fontsize=12)\n",
    "    axes[i].set_xlabel('Churn Rate (%)')\n",
    "    for p in axes[i].patches:\n",
    "        axes[i].annotate(f'{p.get_width():.1f}%',\n",
    "                        (p.get_width() + 0.5, p.get_y() + 0.3))\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "tenure_churn",
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Tenure distribution by churn\n",
    "sns.kdeplot(data=df, x='tenure', hue='Churn', fill=True,\n",
    "           palette={0: '#66b3ff', 1: '#ff9999'}, ax=axes[0])\n",
    "axes[0].set_title('Tenure Distribution by Churn', fontsize=13)\n",
    "axes[0].set_xlabel('Tenure (months)')\n",
    "\n",
    "# Monthly charges distribution by churn\n",
    "sns.boxplot(data=df, x='Churn', y='MonthlyCharges',\n",
    "           palette={0: '#66b3ff', 1: '#ff9999'}, ax=axes[1])\n",
    "axes[1].set_title('Monthly Charges by Churn', fontsize=13)\n",
    "axes[1].set_xticklabels(['No Churn', 'Churn'])\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../images/tenure_vs_churn.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section6",
   "metadata": {},
   "source": ["## 6. Correlation Heatmap"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "heatmap",
   "metadata": {},
   "outputs": [],
   "source": [
    "numeric_df = df.select_dtypes(include='number')\n",
    "\n",
    "plt.figure(figsize=(10, 8))\n",
    "sns.heatmap(numeric_df.corr(), annot=True, fmt='.2f',\n",
    "           cmap='coolwarm', linewidths=0.5, square=True)\n",
    "plt.title('Correlation Matrix of Numeric Features', fontsize=14)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../images/correlation_heatmap.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section7",
   "metadata": {},
   "source": ["## 7. Key Insights Summary"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "insights",
   "metadata": {},
   "outputs": [],
   "source": [
    "print('=== KEY CHURN INSIGHTS ===')\n",
    "print(f\"Overall churn rate: {df.Churn.mean()*100:.1f}%\")\n",
    "print()\n",
    "for col in ['Contract', 'InternetService', 'PaymentMethod', 'SeniorCitizen']:\n",
    "    print(f'Churn rate by {col}:')\n",
    "    print(df.groupby(col)['Churn'].mean().mul(100).round(1).to_string())\n",
    "    print()"
   ]
  }
 ]
}
